# Database Configuration
DATABASE_URL="file:./dev.db"

# JWT Secret Keys (MUST BE STRONG - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="YOUR_STRONG_JWT_SECRET_HERE_32_BYTES_MIN"
JWT_REFRESH_SECRET="YOUR_STRONG_JWT_REFRESH_SECRET_HERE_32_BYTES_MIN"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server Configuration
PORT=5001
NODE_ENV="development"

# CORS - Allowed Origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Production Notes:
# 1. For production, use PostgreSQL instead of SQLite
# 2. DATABASE_URL should point to your PostgreSQL instance
# 3. Generate strong JWT secrets using:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Set NODE_ENV to "production" in production
# 5. Update ALLOWED_ORIGINS to your actual frontend domain
# 6. Use environment variables to manage sensitive data
